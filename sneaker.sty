        .. controls (0.84,1.25) and (1.00,1.24) .. (1.15, 1.23)
        .. controls (1.46,1.19) and (1.80,1.14) .. (2.10, 1.06)
        .. controls (2.28,1.02) and (2.36, 0.98) .. (2.52,0.96)
	-- (2.48,0.92) 
        .. controls (2.3,0.95) and (2.18,0.98) .. (2.05, 1.00)
        .. controls (1.78,1.08) and (1.46,1.16) .. (1.15, 1.17)
        .. controls (1.00,1.18) and (0.84,1.19) .. (0.68, 1.20)
        .. controls (0.56,1.25) and (0.46,1.33) .. (0.34, 1.36)
        .. controls (0.20,1.38) and (0.12,1.30) .. (0.10, 1.18)
        -- cycle;


      %% =============================================================
      %% L4 — near side sole
      %% =============================================================

      \ifsneakerrolls
       %% 1. Parameter für die Aussparung (etwas größer als das Rad für den Gap-Effekt)
        \pgfmathsetmacro{\wellR}{\wheelR + 0.03} 
        \pgfmathsetmacro{\angA}{asin((\soleYA-\wheelY)/\wellR)}
        \pgfmathsetmacro{\angAend}{180-\angA}
        \pgfmathsetmacro{\angAx}{\wellR*cos(\angA)}
        \pgfmathsetmacro{\angB}{asin((\soleYB-\wheelY)/\wellR)}
        \pgfmathsetmacro{\angBend}{180-\angB}
        \pgfmathsetmacro{\angBx}{\wellR*cos(\angB)}

        %% 2. DIE TECHNISCHE SCHIENE (Halterung aus Bild 4)
        % Diese Schiene verbindet die Räder optisch und gibt Stabilität

	\foreach \wx/\sy in {\wA/\soleYA, \wB/\soleYB} {
    %% 1. DIE SEITENWAND (Rechts - erzeugt die Tiefe)
    \fill[black!30, draw=black!50, line width=0.3pt]
      ({\wx+0.25}, \wheelY)                     % Unten Vorne
      -- ({\wx+0.25+\dx}, \wheelY+\dy)          % Unten Hinten
      -- ({\wx+0.25+\dx}, \sy+\dy)                   % Oben Hinten (bündig Sohle)
      -- ({\wx+0.25}, \sy)                            % Oben Vorne (bündig Sohle)
      -- cycle;

    %% 2. DIE UNTERSEITE (mit deiner Kurve)
    \fill[black!15, draw=black!45, line width=0.3pt]
      ({\wx-0.25}, \wheelY) 
      .. controls ({\wx-0.02}, \wheelY) and ({\wx+0.02}, \wheelY+0.01) .. ({\wx+0.25}, \wheelY) 
      -- ({\wx+0.25+\dx}, \wheelY+\dy)
      .. controls ({\wx+0.02+\dx}, \wheelY+0.01+\dy) and ({\wx-0.02+\dx}, \wheelY+\dy) .. ({\wx-0.25+\dx}, \wheelY+\dy)
      -- cycle;

    %% 3. DIE VORDERSEITE
    \fill[black!22, draw=black!45, line width=0.3pt]
      ({\wx-0.25}, 0.13)                               % Oben Links
      -- ({\wx+0.25}, 0.13)                            % Oben Rechts
      -- ({\wx+0.25}, \wheelY)                   % Unten Rechts
      .. controls ({\wx+0.02}, \wheelY+0.01) and ({\wx-0.02}, \wheelY) .. ({\wx-0.25}, \wheelY) 
      -- cycle;
}
        
        % Kleine Achsschrauben-Andeutungen auf der Schiene
        \foreach \wx in {\wA, \wB} {
            \fill[black!30] (\wx, \wheelY+0.09) circle (0.02);
        }

        %% 3. SOHLE MIT WEICHEN AUSSPARUNGEN
        \fill[SoleCol, draw=black!40, line width=0.4pt]
          (0.16, 0)
          .. controls (0.1, 0) and (0.04, 0.14) .. (0.06, 0.34)
          .. controls (0.3, 0.31) and (0.55, 0.27) .. (1.13, 0.34)
          .. controls (1.6, 0.45) and (2.2, 0.3) .. (2.5, 0.34)
          .. controls (2.80, 0.38) and (2.95, 0.43) .. (3.0+\dx*0.64, 0.34+\dy*0.64)
          .. controls ({2.96+\dx*0.8}, {0.34+\dy*0.8+\bump/2})
          .. ({2.98+\dx}, {0.34+\dy})
          .. controls ({3.06+\dx},{0.34+\dy}) and ({3.16+\dx},{0.11+\dy})
          .. ({3.13+\dx}, {0.1+\dy})
          .. controls (3.0+\dx*0.8, 0.1+\dy*0.41) .. (3.0+\dx*0.68, 0.1+\dy*0.4)
          .. controls (2.95, 0.09) and (2.80, 0.04) .. (2.53, 0)
          % Weicher Übergang zu Rad B
          .. controls (2.45, 0.01) .. ({\wB+\angBx}, \soleYB)
          arc[start angle={\angB}, end angle={\angBend}, radius=\wellR]
          % Flache Brücke zwischen den Rädern (wie in Bild 4)
          .. controls (1.50, 0.12) .. ({\wA+\angAx}, \soleYA)
          arc[start angle={\angA}, end angle={\angAend}, radius=\wellR]
          % Übergang zur Ferse
          .. controls (0.40, 0.02) .. (0.17, 0)
          -- cycle;

        \draw[black!13, line width=0.25pt] \soleMiddleLine;

        %% 4. RÄDER (Vordergrund)
        \foreach \wx in {\wA, \wB} {
          % Reifenaußenseite (dunkler Ring)
          \fill[black!85, draw=black, line width=0.3pt] (\wx, \wheelY) circle (\wheelR);
          % Felge (heller Kern)
          \fill[white!95!black, draw=black!30, line width=0.2pt] (\wx, \wheelY) circle ({\wheelR*0.75});
          % Speichen/Design
          \foreach \a in {0,60,...,300} {
            \draw[black!15, line width=0.2pt] (\wx, \wheelY) -- +(\a:{\wheelR*0.7});
          }
          % Achse
          \fill[gray!40, draw=black!40, line width=0.2pt] (\wx, \wheelY) circle (\hubR);
          \fill[black!70] (\wx, \wheelY) circle (\axleR);
        }
      \else
        \fill[SoleCol, draw=black!40, line width=0.4pt]
          \sole -- cycle;
        \draw[black!13, line width=0.25pt] \soleMiddleLine;
      \fi

      %% =============================================================
      %% features
      %% =============================================================

      %% ---- stitching handled by side patch outline above ----
 
      %% ---- pattern ----
      \ifsneakerpattern
        \def\tmpbolt{bolt}
        \def\tmpstar{star}
        \ifx\sneakerPatternType\tmpstar
          \fill[PatternCol, opacity=0.88]
            (1.30, 0.84) -- (1.37, 0.71) -- (1.55, 0.66)
            -- (1.40, 0.60) -- (1.44, 0.46)
            -- (1.30, 0.54) -- (1.16, 0.46)
            -- (1.20, 0.60) -- (1.05, 0.66)
            -- (1.23, 0.71) -- cycle;
          \draw[PatternCol!50!black, line width=0.3pt, opacity=0.5]
            (1.30, 0.84) -- (1.37, 0.71) -- (1.55, 0.66)
            -- (1.40, 0.60) -- (1.44, 0.46)
            -- (1.30, 0.54) -- (1.16, 0.46)
            -- (1.20, 0.60) -- (1.05, 0.66)
            -- (1.23, 0.71) -- cycle;
        \else
          \fill[PatternCol, opacity=0.88]
            (1.09, 0.88) -- (1.34, 0.70) -- (1.17, 0.70)
            -- (1.51, 0.48) -- (1.39, 0.63) -- (1.56, 0.63) -- cycle;
          \draw[PatternCol!50!black, line width=0.3pt, opacity=0.5]
            (1.09, 0.88) -- (1.34, 0.70) -- (1.17, 0.70)
            -- (1.51, 0.48) -- (1.39, 0.63) -- (1.56, 0.63) -- cycle;
        \fi
      \fi
 
     %% ---- eyelets near side ----
      \ifsneakereyelets
        \foreach \i in {0,...,4} {
          \pgfmathsetmacro{\t}{\i/4}
          \pgfmathsetmacro{\nex}{1.15 + \t*(2.10-1.15)}
          \pgfmathsetmacro{\ney}{1.20 + \t*(1.00-1.20) - 0.06}
          \fill[gray!40] (\nex, \ney) circle (0.050);
          \fill[black!50] (\nex, \ney) circle (0.025);
        }
      \fi
  
      %% ---- laces ----
      \ifsneakerlaces
        \pgfmathsetmacro{\outx}{0.062}
        \pgfmathsetmacro{\outy}{0.11}
        \pgfmathsetmacro{\inx}{0.01}
        \pgfmathsetmacro{\iny}{-0.05}

        \ifsneakervelcro
          \pgfmathsetmacro{\t}{0}
          \pgfmathsetmacro{\nex}{1.15 + \t*(2.10-1.15)}
          \pgfmathsetmacro{\ney}{1.20 + \t*(1.00-1.20) - 0.08}
          \pgfmathsetmacro{\fex}{1.15 + \t*(2.10-1.15) + \dx}
          \pgfmathsetmacro{\fey}{1.20 + \t*(1.00-1.20) + \dy}
          \draw[LaceCol, line width=0.7pt] (\nex, \ney) -- (\fex, \fey);
          \foreach \i in {0,...,1} {
            \pgfmathsetmacro{\ta}{\i/4}
            \pgfmathsetmacro{\tb}{(\i+1)/4}
            \pgfmathsetmacro{\nexa}{1.15 + \ta*(2.10-1.15)}
            \pgfmathsetmacro{\neya}{1.20 + \ta*(1.00-1.20) - 0.06}
            \pgfmathsetmacro{\nexb}{1.15 + \tb*(2.10-1.15)}
            \pgfmathsetmacro{\neyb}{1.20 + \tb*(1.00-1.20) - 0.06}
            \pgfmathsetmacro{\fexa}{1.15 + \ta*(2.10-1.15) + \dx}
            \pgfmathsetmacro{\feya}{1.20 + \ta*(1.00-1.20) + \dy}
            \pgfmathsetmacro{\fexb}{1.15 + \tb*(2.10-1.15) + \dx}
            \pgfmathsetmacro{\feyb}{1.20 + \tb*(1.00-1.20) + \dy}
            \draw[LaceCol, line width=0.7pt]
              (\nexa, \neya) -- ({\fexb+\inx}, {\feyb+\iny});
            \draw[LaceCol, line width=0.7pt]
              (\fexa + 0.01, \feya + 0.01) -- (\nexb + \outx, \neyb+ \outy);
            \pgfmathsetmacro{\tend}{(2)/4}
            \pgfmathsetmacro{\nex}{1.15 + \tend*(2.10-1.15)}
            \pgfmathsetmacro{\ney}{1.20 + \tend*(1.00-1.20) - 0.06}
            \draw[LaceCol, line width=0.7pt] (\nex, \ney) -- ({\nex+\dx}, {\ney+\dy});
          }
        \else
          \pgfmathsetmacro{\t}{0}
          \pgfmathsetmacro{\nex}{1.15 + \t*(2.10-1.15)}
          \pgfmathsetmacro{\ney}{1.20 + \t*(1.00-1.20) - 0.06}
          \pgfmathsetmacro{\fex}{1.15 + \t*(2.10-1.15) + \dx}
          \pgfmathsetmacro{\fey}{1.20 + \t*(1.00-1.20) + \dy}
          \draw[LaceCol, line width=0.7pt] (\nex, \ney) -- (\fex, \fey);
          \foreach \i in {0,...,3} {
            \pgfmathsetmacro{\ta}{\i/4}
            \pgfmathsetmacro{\tb}{(\i+1)/4}
            \pgfmathsetmacro{\nexa}{1.15 + \ta*(2.10-1.15)}
            \pgfmathsetmacro{\neya}{1.20 + \ta*(1.00-1.20) - 0.06}
            \pgfmathsetmacro{\nexb}{1.15 + \tb*(2.10-1.15)}
            \pgfmathsetmacro{\neyb}{1.20 + \tb*(1.00-1.20) - 0.06}
            \pgfmathsetmacro{\fexa}{1.15 + \ta*(2.10-1.15) + \dx}
            \pgfmathsetmacro{\feya}{1.20 + \ta*(1.00-1.20) + \dy}
            \pgfmathsetmacro{\fexb}{1.15 + \tb*(2.10-1.15) + \dx}
            \pgfmathsetmacro{\feyb}{1.20 + \tb*(1.00-1.20) + \dy}
            \ifnum\i=3
              \draw[LaceCol, line width=0.7pt]
                (\nexa, \neya) -- ({\fexb+\inx-0.1}, {\feyb+\iny-0.02});
            \else
              \draw[LaceCol, line width=0.7pt]
                (\nexa, \neya) -- ({\fexb+\inx}, {\feyb+\iny});
            \fi
            \draw[LaceCol, line width=0.7pt]
              (\fexa + 0.075, \feya - \i * 0.013) -- (\nexb + \outx, \neyb+ \outy);
            \pgfmathsetmacro{\tend}{(4)/4}
            \pgfmathsetmacro{\nex}{1.15 + \tend*(2.10-1.15)}
            \pgfmathsetmacro{\ney}{1.20 + \tend*(1.00-1.20)}
            \draw[LaceCol, line width=0.7pt]
              (\nex, \ney -0.06) -- ({\nex+\dx}, {\ney+\dy-0.03});
          }
        \fi

        %% bow
        \pgfmathsetmacro{\bx}{1.18 + \dx*0.5}
        \pgfmathsetmacro{\by}{1.20 + \dy*0.5 + 0.01}
        \begin{scope}[shift={(\bx,\by)}, rotate=37, yscale=0.8, xscale=1.1]
          \draw[LaceCol, fill=LaceCol] (0,0) circle (0.02);
          \draw[LaceCol, line width=0.8pt, line cap=round]
            (0,0) .. controls (-0.4, 0.4) and (-0.8, 0.1) .. (0,0);
          \draw[LaceCol, line width=0.8pt, line cap=round]
            (0,0) .. controls (0.5, -0.3) and (0.9, 0.1) .. (0,0);
          \draw[LaceCol, line width=0.7pt, line cap=round]
            (0,0) .. controls (-0.2, -0.1) .. (-0.5, -0.2);
          \draw[LaceCol, line width=0.7pt, line cap=round]
            (0,0) .. controls (0.2, -0.4) .. (0.6, -0.5);
        \end{scope}
      \fi
 
      %% ---- velcro ----
      \ifsneakervelcro
        \ifsneakerlaces
          \pgfmathsetmacro{\ta}{0.70}
          \pgfmathsetmacro{\tb}{0.95}
          \pgfmathsetmacro{\na}{1.15 + \ta*(2.10-1.15)}
          \pgfmathsetmacro{\naz}{1.20 + \ta*(1.00-1.20)}
          \pgfmathsetmacro{\nb}{1.15 + \tb*(2.10-1.15)}
          \pgfmathsetmacro{\nbz}{1.20 + \tb*(1.00-1.20)}
          \pgfmathsetmacro{\fa}{\na + \dx}
          \pgfmathsetmacro{\faz}{\naz + \dy}
          \pgfmathsetmacro{\fb}{\nb + \dx}
          \pgfmathsetmacro{\fbz}{\nbz + \dy}
          \fill[gray!15, draw=gray!55, line width=0.5pt]
            (\na, \naz) -- (\fa, \faz) -- (\fb, \fbz) -- (\nb, \nbz) -- cycle;
          \pgfmathsetmacro{\mx}{(\na+\fb)/2}
          \pgfmathsetmacro{\my}{(\naz+\fbz)/2}
          \foreach \jj in {-0.08,-0.02,0.04,0.10} {
            \foreach \kk in {-0.03,0.03} {
              \fill[gray!40] ({\mx+\jj},{\my+\kk}) circle (0.011);
            }
          }
          \fill[gray!30, draw=gray!60, line width=0.4pt]
            ({\fa-0.02},\faz) -- ({\fa+0.06},{\faz+0.02})
            -- ({\fb+0.06},{\fbz+0.02}) -- ({\fb-0.02},\fbz) -- cycle;
        \else
          \foreach \i in {0,1} {
            \pgfmathsetmacro{\ta}{0.12 + \i*0.42}
            \pgfmathsetmacro{\tb}{\ta + 0.22}
            \pgfmathsetmacro{\na}{1.15 + \ta*(2.10-1.15)}
            \pgfmathsetmacro{\naz}{1.20 + \ta*(1.00-1.20)}
            \pgfmathsetmacro{\nb}{1.15 + \tb*(2.10-1.15)}
            \pgfmathsetmacro{\nbz}{1.20 + \tb*(1.00-1.20)}
