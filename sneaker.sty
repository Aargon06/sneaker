        % Schatten von der nahen Wand (links/unten)
        \fill[black, opacity=0.2] (1.1, 1.2) -- (2.2, 0.9) -- (2.2, 1.0) -- (1.1, 1.3) -- cycle;
        % Schatten von der hinteren Wand (oben)
        \fill[black, opacity=0.1] ({1.29+\dx}, {1.38+\dy}) circle (0.3);
      \end{scope}

	%%top part after tongue
	\fill[MainCol, draw=black!30, line width=0.3pt]
    (2.17, 0.94)  
    .. controls (2.60,0.68) and (2.80,0.50) .. (2.95, 0.33)
    .. controls ({2.95+\dx*0.5}, {0.34+\dy*0.5-\bump}) 
    .. ({2.98+\dx}, {0.35+\dy})                          
    ..  controls  ({2.80+\dx},{0.55+\dy}) and ({2.50+\dx},{0.78+\dy})
    .. ({2.10+\dx}, {0.94+\dy-0.01}) 
    .. controls ({2.10+\dx*0.5}, {0.94+\dy*0.5+\bumpToe}) 
    .. (2.17, 0.94) -- cycle;
 
      %% ---- toe cap top ----
      \fill[ToeTopCol, draw=black!30, line width=0.3pt, opacity=100]
        (2.35, 0.80)
        .. controls (2.60,0.68) and (2.80,0.50) .. (2.95, 0.33)
        .. controls ({2.95+\dx*0.5}, {0.34+\dy*0.5-\bump})
        .. ({2.98+\dx}, {0.35+\dy})
        .. controls ({2.82+\dx},{0.50+\dy}) and ({2.60+\dx},{0.68+\dy})
        .. ({2.36+\dx}, {0.81+\dy})
        .. controls ({2.35+\dx*0.5}, {0.80+\dy*0.5+\bump})
        .. (2.35, 0.80);
 
      %% =============================================================
      %% L3 — near side upper
      %% =============================================================
 
      \fill[MainCol, draw=black!45, line width=0.4pt]
        \sneakerUpperNear -- cycle;
 
      \fill[ToeCol, draw=black!45, line width=0.4pt, opacity=100]
        (2.40, 0.3)
	.. controls (2.43, 0.3) and (2.47, 0.32) .. (2.5, 0.34)
        .. controls (2.80, 0.38) and (2.95, 0.43)  .. (3.0+\dx*0.64, 0.34+\dy*0.64)
        .. controls (3.22,0.78) and (2.55,0.92) .. (2.52, 0.95)
        .. controls (2.32,0.68) and (2.34,0.52) .. (2.4, 0.34);
 
      \fill[DarkCol, draw=black!45, line width=0.4pt]
        (0.12, 0.34)
        .. controls (0.04,0.50) and (0.02,0.72) .. (0.02, 0.88)
        .. controls (0.02,1.02) and (0.04,1.14) .. (0.08, 1.2)
        .. controls (0.16, 1.14) and (0.27, 1.13) .. (0.36, 1.12)
        .. controls (0.37, 0.75) and (0.40, 0.45) .. (0.48, 0.31)
	.. controls (0.32, 0.3) and (0.2, 0.33) .. (0.13, 0.34)
        -- cycle;
 
      %% ---- side patch (pattern base) ----
